# ============================================
# KONNECT API - ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=4000
PUBLIC_URL=https://api.codesbyjit.site

# ============================================
# DATABASE
# ============================================
MONGO_URI=mongodb://127.0.0.1:27017/Konnect

# ============================================
# JWT AUTHENTICATION
# Generate a strong random string for production
# ============================================
JWT_SECRET=your_super_secret_jwt_key_here

# ============================================
# EMAIL SERVICE (Gmail SMTP)
# Enable 2FA and generate an App Password
# ============================================
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password_here
ADMIN_EMAIL=admin@yourdomain.com

# ============================================
# AI SERVICE (OpenRouter - Free)
# Get free API key from https://openrouter.ai/settings
# Free models: meta-llama/llama-3.2-1b-instruct, gemma-2-2b-it
# ============================================
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3.2-1b-instruct

# ============================================
# INSTAGRAM API
# Get from: https://developers.facebook.com/apps
# Create app → Add Products → Instagram Basic Display + Instagram Graph API
# ============================================
INSTAGRAM_CLIENT_ID=your_instagram_app_id
INSTAGRAM_CLIENT_SECRET=your_instagram_app_secret
INSTAGRAM_REDIRECT_URI=https://api.codesbyjit.site/api/instagram/callback/instagram

# ============================================
# FACEBOOK API
# Get from: https://developers.facebook.com/apps
# Create app → Add Products → Facebook Login
# ============================================
FACEBOOK_CLIENT_ID=your_facebook_app_id
FACEBOOK_CLIENT_SECRET=your_facebook_app_secret
FACEBOOK_REDIRECT_URI=https://api.codesbyjit.site/api/facebook/callback/facebook
FACEBOOK_API_VERSION=v19.0

# ============================================
# LINKEDIN API (Coming Soon)
# Get from: https://www.linkedin.com/developers/apps
# Products needed: "Share on LinkedIn" + "Sign In with LinkedIn using OpenID Connect"
# ============================================
# LINKEDIN_CLIENT_ID=your_linkedin_client_id
# LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
# LINKEDIN_REDIRECT_URI=https://api.codesbyjit.site/api/linkedin/callback

# ============================================
# TWITTER/X API (Coming Soon)
# Get from: https://developer.twitter.com
# Enable: User authentication settings → OAuth 2.0
# ============================================
# TWITTER_CLIENT_ID=your_twitter_client_id
# TWITTER_CLIENT_SECRET=your_twitter_client_secret
# TWITTER_REDIRECT_URI=https://api.codesbyjit.site/api/twitter/callback

# ============================================
# FEATURE FLAGS
# Enable/disable specific social platforms
# ============================================
ENABLE_INSTAGRAM=true
ENABLE_FACEBOOK=true
ENABLE_LINKEDIN=false
ENABLE_TWITTER=false
